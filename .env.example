APP_NAME="Криптон"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Moscow
APP_URL=https://example.com

APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Database -----------------------------------------------------------------
# Dev: SQLite works out of the box (`touch database/database.sqlite`).
# Production on Beget: create a MySQL DB in the hosting panel and fill in below.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=crypton
DB_USERNAME=crypton
DB_PASSWORD=

# --- Session / queue / cache / filesystem -------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
# 'sync' renders mail synchronously during the HTTP request. Switch to
# 'database' + run `php artisan queue:work` via Beget cron for volume;
# 'sync' is fine for a brochure site with < 100 leads/day.
QUEUE_CONNECTION=sync

CACHE_STORE=file
CACHE_PREFIX=

SETTINGS_CACHE_ENABLED=true
SETTINGS_CACHE_STORE=file

# --- Mail (Beget SMTP) --------------------------------------------------------
# Beget provides SMTP via smtp.beget.com:465 (SSL) with the mailbox user you
# created in the panel. The notify_email target for contact-form leads is
# read at runtime from IntegrationSettings (admin UI), not from env.
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.beget.com
MAIL_PORT=465
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Admin bootstrap ----------------------------------------------------------
# AdminUserSeeder reads these on first seed. Change the password immediately
# in /admin after first login.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_NAME=Администратор

# --- Notes --------------------------------------------------------------------
# Cloudflare Turnstile keys live in IntegrationSettings (admin UI), NOT in env.
# `php artisan config:cache` on deploy would otherwise freeze stale values.
# Yandex.Metrika counter ID is also in IntegrationSettings.

VITE_APP_NAME="${APP_NAME}"
